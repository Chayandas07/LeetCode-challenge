class Solution {
public:
    int help(string& s, char ch) {
        int ans = 0;
        int n = s.size();
        
        for(int i = 0; i < n; i++) {
            if(!(i & 1) && s[i] != ch) ans++;
            else if((i & 1) && s[i] == ch) ans++;
        }
        
        return ans;
    }
    
    int minOperations(string s) {
        int opt1 = help(s, '0');
        int opt2 = help(s, '1');
        
        return min(opt1, opt2);
    }
};
