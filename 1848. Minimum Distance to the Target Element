class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int x=-1;
        for(int i=start;i<nums.length;i++){
            if(nums[i]==target){
                x=i-start;
                break;
            }
        }
        int y=-1;
        for(int i=start;i>=0;i--){
            if(nums[i]==target){
                y=start-i;
                break;
            }
        }
        if(x==-1){
            return y;
        }
        if(y==-1){
            return x;
        }
        return Math.min(x,y);
    }
}
